{
    "headers": [
        {
            "source": "/signin",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, follow"
                }
            ]
        },
        {
            "source": "/signup",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, follow"
                }
            ]
        },
        {
            "source": "/forgot-password",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/reset-password",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/chat",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
